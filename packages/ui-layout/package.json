{
  "name": "@ui.base/ui-layout",
  "version": "0.1.0",
  "type": "module",
  "description": "Source-backed layout analysis and safe visual layout editing tools for UI Base components.",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./analyzer": "./src/analyzer/analyze-component.ts",
